{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/lib/lab/types": [
        "../apps/site/lib/lab/types.ts"
      ],
      "@/*": [
        "../apps/site/*"
      ]
    }
  },
  "include": [
    "./*.ts",
    "../apps/site/lib/playground/worker.ts"
  ],
  "exclude": [
    "../node_modules"
  ]
}
