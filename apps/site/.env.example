# Ed25519 PKCS#8 PEM. Required in production; keep this server-only.
JIT_LAB_SIGNING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Created by a private Vercel Blob store.
BLOB_READ_WRITE_TOKEN=

# Bare public HTTPS origin embedded in signed reconstruction references.
JIT_LAB_PUBLIC_ORIGIN=https://jit-site.vercel.app
