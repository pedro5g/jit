{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "lib/**/__tests__/*.test.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".source"
  ]
}
