{
  "name": "@jit/examples-generated",
  "version": "0.0.0",
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.cjs"
    },
    "./catalog": {
      "types": "./catalog.d.ts",
      "import": "./catalog.mjs",
      "require": "./catalog.cjs"
    }
  },
  "sideEffects": false
}
