{
  "name": "@pedro5g/jit",
  "version": "1.0.0",
  "author": "Pedro5g <pedro.env5@gmail.com>",
  "description": "A compiled TypeScript data engine for validation, queries, transforms, serialization, and binary processing",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf ATS aot compiler core errors factories runtime shared transforms *.js *.cjs *.d.ts *.d.cts *.d.mts",
    "build": "zshy --project tsconfig.build.json",
    "test:watch": "pnpm vitest",
    "test": "pnpm vitest run"
  },
  "keywords": [
    "jit",
    "schema",
    "validation",
    "typescript",
    "aot",
    "codegen",
    "serialization",
    "query-engine",
    "compiler",
    "performance"
  ],
  "files": [
    "**/*.js",
    "**/*.mjs",
    "**/*.cjs",
    "**/*.d.ts",
    "**/*.d.mts",
    "**/*.d.cts",
    "**/package.json"
  ],
  "zshy": {
    "exports": {
      "./package.json": "./package.json",
      ".": "./src/index.ts",
      "./cli": "./src/cli.ts",
      "./runtime": "./src/runtime.ts",
      "./define": "./src/define.ts",
      "./mcp": "./src/mcp.ts"
    },
    "conditions": {
      "@jit/source": "src"
    }
  },
  "main": "./index.cjs",
  "types": "./index.d.cts",
  "module": "./index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedro5g/jit.git",
    "directory": "packages/jit"
  },
  "homepage": "https://github.com/pedro5g/jit#readme",
  "bugs": {
    "url": "https://github.com/pedro5g/jit/issues"
  },
  "support": {
    "backing": {
      "npm-funding": true
    }
  },
  "license": "MIT",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@jit/source": "./src/index.ts",
      "types": "./index.d.cts",
      "import": "./index.js",
      "require": "./index.cjs"
    },
    "./cli": {
      "@jit/source": "./src/cli.ts",
      "types": "./cli.d.cts",
      "import": "./cli.js",
      "require": "./cli.cjs"
    },
    "./runtime": {
      "@jit/source": "./src/runtime.ts",
      "types": "./runtime.d.cts",
      "import": "./runtime.js",
      "require": "./runtime.cjs"
    },
    "./define": {
      "@jit/source": "./src/define.ts",
      "types": "./define.d.cts",
      "import": "./define.js",
      "require": "./define.cjs"
    },
    "./mcp": {
      "@jit/source": "./src/mcp.ts",
      "types": "./mcp.d.cts",
      "import": "./mcp.js",
      "require": "./mcp.cjs"
    }
  },
  "bin": {
    "jit": "./cli.js",
    "jit-mcp": "./mcp.js"
  },
  "devDependencies": {
    "@types/node": "^26.1.0"
  },
  "peerDependencies": {
    "jiti": ">=2"
  },
  "peerDependenciesMeta": {
    "jiti": {
      "optional": true
    }
  }
}
