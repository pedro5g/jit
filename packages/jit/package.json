{
  "name": "jit",
  "version": "1.0.0",
  "author": "Pedro5g <pedro.env5@gmail.com>",
  "description": "Just-In-Time (JIT) compilation utilities",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "clean": "git clean -xdf . -e node_modules",
    "build": "zshy --project tsconfig.build.json",
    "test:watch": "pnpm vitest",
    "test": "pnpm vitest run"
  },
  "keywords": [
    "JIT",
    "compiler",
    "TS",
    "types"
  ],
  "files": [
    "src",
    "**/*.js",
    "**/*.mjs",
    "**/*.cjs",
    "**/*.d.ts",
    "**/*.d.mts",
    "**/*.d.cts",
    "**/package.json"
  ],
  "zshy": {
    "exports": {
      "./package.json": "./package.json",
      ".": "./src/index.ts"
    },
    "conditions": {
      "@jit/source": "src"
    }
  },
  "main": "./index.cjs",
  "types": "./index.d.cts",
  "module": "./index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedro5g/jit.git"
  },
  "support": {
    "backing": {
      "npm-funding": true
    }
  },
  "license": "MIT",
  "packageManager": "pnpm@10.30.1",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@jit/source": "./src/index.ts",
      "types": "./index.d.cts",
      "import": "./index.js",
      "require": "./index.cjs"
    }
  }
}
